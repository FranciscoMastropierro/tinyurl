{
  "name": "tinyurl",
  "version": "1.0.0",
  "description": "TinyURL backend challenge - Fastify, MongoDB, Redis, AWS SQS",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/click.worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/workers/click.worker.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tinyurl",
    "fastify",
    "typescript"
  ],
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1068.0",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "mongoose": "^8.19.4",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
