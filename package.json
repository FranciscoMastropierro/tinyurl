    "ioredis": "^5.11.1",
    "mongoose": "^8.19.4",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
