{
  "name": "tinyurl",
  "version": "1.0.0",
  "description": "TinyURL backend challenge - Fastify, MongoDB, Redis, BullMQ",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/click.worker.ts",
